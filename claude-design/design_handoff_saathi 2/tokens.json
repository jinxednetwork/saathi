{
  "$schema": "https://design-tokens.org/tokens.json",
  "name": "Saathi Design System",
  "description": "Calm, warm, gently gamified wellbeing companion for students under exam pressure. Type: Fredoka (display/UI, 500) + Nunito (body, 400/500). Sentence case everywhere; deliberately no 600/700 weights.",
  "color": {
    "base": {
      "bg":             { "value": "#F7F4E9", "comment": "Warm cream app background — never stark white" },
      "surface":        { "value": "#FFFFFF", "comment": "Cards, inputs, speech bubbles" },
      "surface-sunken": { "value": "#EFEBDD", "comment": "Inset/pressed, pending dots, input borders" },
      "canvas":         { "value": "#E7E5DD", "comment": "Neutral page behind device frame (prototype)" }
    },
    "brand": {
      "primary":      { "value": "#639922", "comment": "CTAs, mascot default, active states" },
      "primary-soft": { "value": "#EAF3DE", "comment": "Selected fills, success-tint cards, chips" },
      "primary-ink":  { "value": "#3B6D11", "comment": "Text/icons on primary-soft" },
      "reward":       { "value": "#EF9F27", "comment": "XP / streak / confetti accents — used sparingly" },
      "reward-soft":  { "value": "#FAEEDA", "comment": "Reward stat cards, streak chip background" },
      "reward-ink":   { "value": "#854F0B", "comment": "Text on reward-soft" }
    },
    "crisis": {
      "surface": { "value": "#E6F1FB", "comment": "Helpline panel — calm blue, never red" },
      "ink":     { "value": "#0C447C", "comment": "Text on crisis surface" },
      "ink-2":   { "value": "#3A6EA5", "comment": "Secondary text on crisis surface" }
    },
    "text": {
      "ink":       { "value": "#2C2C2A", "comment": "Primary text" },
      "ink-muted": { "value": "#5F5E5A", "comment": "Secondary text" },
      "ink-hint":  { "value": "#888780", "comment": "Placeholders, inactive, hints" }
    },
    "mood": {
      "comment": "1=low ... 5=great. Color is NEVER the sole signal — paired with mouth-curve shape + text label.",
      "1": { "value": "#C25B3F", "label": "Low" },
      "2": { "value": "#D08A4A", "label": "Meh" },
      "3": { "value": "#B6A93C", "label": "Okay" },
      "4": { "value": "#7DA93A", "label": "Good" },
      "5": { "value": "#639922", "label": "Great" }
    },
    "mascot": {
      "comment": "User-selectable companion colors, mid-chroma & friendly.",
      "sage":       { "value": "#639922" },
      "blue":       { "value": "#5B8DB8" },
      "terracotta": { "value": "#E08A5B" },
      "lavender":   { "value": "#9B86C4" },
      "gold":       { "value": "#E0A93E" },
      "teal":       { "value": "#4FA399" }
    }
  },
  "typography": {
    "family": {
      "display": { "value": "Fredoka", "comment": "Display/UI, weight 500 only" },
      "body":    { "value": "Nunito",  "comment": "Body, weights 400/500" }
    },
    "weight": {
      "regular": { "value": 400 },
      "medium":  { "value": 500, "comment": "Heaviest used — no 600/700, keeps tone soft" }
    },
    "size": {
      "hint":       { "value": "11px" },
      "label":      { "value": "13px" },
      "body":       { "value": "16px", "comment": "Min on inputs to avoid iOS zoom" },
      "screen":     { "value": "18px" },
      "display":    { "value": "23px" },
      "numeric-sm": { "value": "34px", "comment": "Level" },
      "numeric-lg": { "value": "54px", "comment": "Streak / focus timer" }
    },
    "lineHeight": {
      "body":  { "value": 1.6, "comment": "Journaling: 1.5–1.7" },
      "tight": { "value": 1.15 }
    },
    "case": { "value": "sentence", "comment": "Sentence case everywhere except tiny eyebrow labels" }
  },
  "spacing": {
    "comment": "4px base scale. Card padding lg–xl.",
    "xs":  { "value": "4px" },
    "sm":  { "value": "8px" },
    "md":  { "value": "12px" },
    "lg":  { "value": "16px" },
    "xl":  { "value": "24px" },
    "2xl": { "value": "32px" }
  },
  "radius": {
    "sm":   { "value": "8px" },
    "md":   { "value": "16px", "comment": "Default" },
    "lg":   { "value": "20px" },
    "pill": { "value": "28px", "comment": "Cards / CTAs" },
    "full": { "value": "9999px", "comment": "Dots, avatars, swatches, mascot bubble" }
  },
  "motion": {
    "duration": {
      "micro":  { "value": "150ms" },
      "view":   { "value": "200ms" },
      "reward": { "value": "350ms" }
    },
    "easing": {
      "out":    { "value": "cubic-bezier(0.22, 1, 0.36, 1)", "comment": "View transitions" },
      "spring": { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "comment": "Reward pop/bounce" }
    },
    "rules": {
      "comment": "Transform + opacity only. Every animation needs a prefers-reduced-motion collapse to a visible resting state — nothing may depend on an entrance animation to become visible."
    }
  },
  "shadow": {
    "card":   { "value": "0 1px 2px rgba(44,44,42,.04)", "comment": "Keep elevation subtle/flat" },
    "sheet":  { "value": "0 -12px 40px -16px rgba(44,50,20,.25)" },
    "device": { "value": "0 40px 80px -28px rgba(40,50,20,.55)", "comment": "Prototype device frame only" }
  },
  "themes": {
    "dark": {
      "comment": "Late-night studying. Warm-neutral dark bg, lifted surfaces, same sage primary. Verify AA before shipping.",
      "color": {
        "bg": "#1B1A16", "surface": "#262420", "surface-sunken": "#201E1A", "canvas": "#121210",
        "primary": "#7CB534", "primary-soft": "#2E3A1E", "primary-ink": "#B7DA86",
        "reward": "#F2AA3D", "reward-soft": "#3A2E18", "reward-ink": "#F3C57E",
        "crisis-surface": "#15293D", "crisis-ink": "#BFD8F0", "crisis-ink-2": "#8DB2D6",
        "ink": "#ECE9E0", "ink-muted": "#B4B0A6", "ink-hint": "#847F75"
      }
    }
  }
}
